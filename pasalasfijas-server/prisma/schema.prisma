generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
  DELETED
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELLED
  EXPIRED
  TRIALING
}

enum MatchStatus {
  SCHEDULED
  LIVE
  FINISHED
  POSTPONED
  CANCELLED
}

enum Side {
  HOME
  AWAY
}

enum ConfidenceLevel {
  HIGH
  MEDIUM
  LOW
  NO_BET
}

enum AnalysisStatus {
  PENDING
  COMPLETED
  FAILED
  REVIEW_REQUIRED
}

enum PickMarket {
  MATCH_WINNER
  DOUBLE_CHANCE
  OVER_UNDER_GOALS
  BTTS
  HANDICAP
  CORNERS
  CARDS
}

enum PickType {
  MAIN
  ALTERNATIVE
  COMBO_LEG
}

enum PickResultStatus {
  PENDING
  WON
  LOST
  VOID
  HALF_WON
  HALF_LOST
}

enum AccessType {
  FREE_UNLOCK
  PREMIUM
  ADMIN
}

model User {
  id              Int                  @id @default(autoincrement())
  email           String               @unique @db.VarChar(255)
  passwordHash    String
  name            String?              @db.VarChar(255)
  emailVerified   Boolean              @default(false)
  lastLoginAt     DateTime?            @db.Timestamptz(6)
  role            UserRole             @default(USER)
  status          UserStatus           @default(ACTIVE)
  profile         UserProfile?
  subscriptions   Subscription[]
  predictionViews UserPredictionView[]
  bankroll        UserBankroll?
  betTrackings    UserBetTracking[]
  createdAt       DateTime             @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime             @updatedAt @db.Timestamptz(6)
}

model UserProfile {
  id                Int     @id @default(autoincrement())
  userId            Int     @unique
  firstName         String? @db.VarChar(100)
  lastName          String? @db.VarChar(100)
  phone             String? @db.VarChar(20)
  document          String? @db.VarChar(50)
  address           String? @db.VarChar(255)
  city              String? @db.VarChar(100)
  country           String? @db.VarChar(100)
  postalCode        String? @db.VarChar(20)
  timezone          String? @default("America/Lima") @db.VarChar(100)
  preferredLanguage String? @default("es") @db.VarChar(50)
  avatarUrl         String? @db.VarChar(255)
  gender            String? @db.VarChar(20)
  occupation        String? @db.VarChar(100)
  riskPreference    String? @default("CONSERVATIVE") @db.VarChar(50)
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Plan {
  id                    Int            @id @default(autoincrement())
  code                  String         @unique
  name                  String
  price                 Decimal        @default(0)
  currency              String         @default("USD")
  dailyFreePredictions  Int            @default(2)
  canViewAllPredictions Boolean        @default(false)
  canViewCombos         Boolean        @default(false)
  canViewStake          Boolean        @default(false)
  canViewHistory        Boolean        @default(false)
  isActive              Boolean        @default(true)
  subscriptions         Subscription[]
}

model Subscription {
  id                     Int                @id @default(autoincrement())
  userId                 Int
  planId                 Int
  status                 SubscriptionStatus @default(ACTIVE)
  startedAt              DateTime           @default(now()) @db.Timestamptz(6)
  expiresAt              DateTime?          @db.Timestamptz(6)
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  user                   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   Plan               @relation(fields: [planId], references: [id])
  createdAt              DateTime           @default(now()) @db.Timestamptz(6)
  updatedAt              DateTime           @updatedAt @db.Timestamptz(6)

  @@index([userId, status])
}

model Competition {
  id         Int      @id @default(autoincrement())
  externalId String?  @unique
  name       String
  country    String?
  type       String?
  logoUrl    String?
  seasons    Season[]
  matches    Match[]
}

model Season {
  id            Int         @id @default(autoincrement())
  competitionId Int
  externalId    String?
  name          String?
  year          Int?
  startDate     DateTime?   @db.Timestamptz(6)
  endDate       DateTime?   @db.Timestamptz(6)
  status        String?
  competition   Competition @relation(fields: [competitionId], references: [id])
  matches       Match[]
}

model Team {
  id          Int                      @id @default(autoincrement())
  externalId  String?                  @unique
  name        String
  shortName   String?
  country     String?
  logoUrl     String?
  homeMatches Match[]                  @relation("HomeTeam")
  awayMatches Match[]                  @relation("AwayTeam")
  absences    PlayerAbsence[]
  forms       TeamRecentForm[]
  stats       MatchTeamStatsSnapshot[]
  standings   StandingSnapshot[]
}

model Match {
  id              Int                      @id @default(autoincrement())
  externalId      String?                  @unique
  competitionId   Int
  seasonId        Int?
  homeTeamId      Int
  awayTeamId      Int
  kickoffAt       DateTime                 @db.Timestamptz(6)
  status          MatchStatus              @default(SCHEDULED)
  venue           String?
  stageLabel      String?
  homeScore       Int?
  awayScore       Int?
  winnerTeamId    Int?
  competition     Competition              @relation(fields: [competitionId], references: [id])
  season          Season?                  @relation(fields: [seasonId], references: [id])
  homeTeam        Team                     @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam        Team                     @relation("AwayTeam", fields: [awayTeamId], references: [id])
  forms           TeamRecentForm[]
  statsSnapshots  MatchTeamStatsSnapshot[]
  standings       StandingSnapshot[]
  absences        PlayerAbsence[]
  odds            OddsSnapshot[]
  analyses        AiAnalysis[]
  picks           Pick[]
  predictionViews UserPredictionView[]
  createdAt       DateTime                 @default(now()) @db.Timestamptz(6)
  updatedAt       DateTime                 @updatedAt @db.Timestamptz(6)

  @@index([kickoffAt])
  @@index([status])
  @@index([competitionId])
}

model TeamRecentForm {
  id            Int      @id @default(autoincrement())
  teamId        Int
  matchId       Int?
  scope         String
  last5Summary  Json?
  last10Summary Json?
  wins          Int      @default(0)
  draws         Int      @default(0)
  losses        Int      @default(0)
  goalsFor      Int      @default(0)
  goalsAgainst  Int      @default(0)
  cleanSheets   Int      @default(0)
  failedToScore Int      @default(0)
  avgXg         Decimal?
  avgXga        Decimal?
  team          Team     @relation(fields: [teamId], references: [id])
  match         Match?   @relation(fields: [matchId], references: [id])
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
}

model MatchTeamStatsSnapshot {
  id                  Int      @id @default(autoincrement())
  matchId             Int
  teamId              Int
  side                Side
  goalsForAvg         Decimal?
  goalsAgainstAvg     Decimal?
  xgAvg               Decimal?
  xgaAvg              Decimal?
  shotsAvg            Decimal?
  shotsOnTargetAvg    Decimal?
  cornersForAvg       Decimal?
  cornersAgainstAvg   Decimal?
  cardsAvg            Decimal?
  bttsRate            Decimal?
  over15Rate          Decimal?
  over25Rate          Decimal?
  over35Rate          Decimal?
  cleanSheetRate      Decimal?
  firstGoalRate       Decimal?
  match               Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team                Team     @relation(fields: [teamId], references: [id])
  createdAt           DateTime @default(now()) @db.Timestamptz(6)
}

model StandingSnapshot {
  id             Int      @id @default(autoincrement())
  matchId        Int
  teamId         Int
  position       Int?
  points         Int?
  played         Int?
  wins           Int?
  draws          Int?
  losses         Int?
  goalsFor       Int?
  goalsAgainst   Int?
  goalDifference Int?
  contextLabel   String?
  match          Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team           Team     @relation(fields: [teamId], references: [id])
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
}

model PlayerAbsence {
  id         Int      @id @default(autoincrement())
  matchId    Int
  teamId     Int
  playerName String
  reason     String?
  importance String?
  position   String?
  isStarter  Boolean  @default(false)
  source     String?
  match      Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team       Team     @relation(fields: [teamId], references: [id])
  createdAt  DateTime @default(now()) @db.Timestamptz(6)
}

model OddsSnapshot {
  id                 Int      @id @default(autoincrement())
  matchId            Int
  market             String
  selection          String
  odd                Decimal
  impliedProbability Decimal?
  provider           String?
  capturedAt         DateTime @default(now()) @db.Timestamptz(6)
  match              Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model AiAnalysis {
  id            Int             @id @default(autoincrement())
  matchId       Int
  model         String
  promptVersion String
  inputHash     String?
  status        AnalysisStatus  @default(PENDING)
  confidence    ConfidenceLevel @default(LOW)
  riskScore     Int?
  summary       String?
  reasonToBet   String?
  reasonToAvoid String?
  conclusion    String?
  noBetReason   String?
  rawInputJson  Json?
  rawOutputJson Json?
  match         Match           @relation(fields: [matchId], references: [id], onDelete: Cascade)
  picks         Pick[]
  comboBets     ComboBet[]
  createdAt     DateTime        @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @db.Timestamptz(6)

  @@index([matchId])
}

model Pick {
  id                    Int              @id @default(autoincrement())
  analysisId            Int
  matchId               Int
  market                PickMarket
  selection             String
  pickType              PickType         @default(ALTERNATIVE)
  confidence            ConfidenceLevel
  riskScore             Int?
  valueScore            Int?
  suggestedStakePercent Int?
  odd                   Decimal?
  probabilityEstimated  Decimal?
  expectedValue         Decimal?
  rationale             String?
  status                String           @default("PUBLISHED")
  resultStatus          PickResultStatus @default(PENDING)
  analysis              AiAnalysis       @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  match                 Match            @relation(fields: [matchId], references: [id], onDelete: Cascade)
  comboLegs             ComboBetLeg[]
  userTrackings         UserBetTracking[]
  createdAt             DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime         @updatedAt @db.Timestamptz(6)

  @@index([matchId])
  @@index([analysisId])
}

model ComboBet {
  id                    Int              @id @default(autoincrement())
  analysisId            Int
  title                 String
  confidence            ConfidenceLevel
  riskScore             Int?
  totalOdd              Decimal?
  suggestedStakePercent Int?
  rationale             String?
  status                String           @default("PUBLISHED")
  resultStatus          PickResultStatus @default(PENDING)
  analysis              AiAnalysis       @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  legs                  ComboBetLeg[]
  createdAt             DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime         @updatedAt @db.Timestamptz(6)
}

model ComboBetLeg {
  id         Int      @id @default(autoincrement())
  comboBetId Int
  pickId     Int
  order      Int      @default(1)
  comboBet   ComboBet @relation(fields: [comboBetId], references: [id], onDelete: Cascade)
  pick       Pick     @relation(fields: [pickId], references: [id])
}

model UserPredictionView {
  id         Int        @id @default(autoincrement())
  userId     Int
  matchId    Int
  viewedAt   DateTime   @default(now()) @db.Timestamptz(6)
  accessType AccessType
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  match      Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@index([userId, viewedAt])
}

model UserBankroll {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  initialAmount Decimal
  currentAmount Decimal
  currency      String   @default("USD")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @db.Timestamptz(6)
}

model UserBetTracking {
  id          Int              @id @default(autoincrement())
  userId      Int
  pickId      Int
  stakeAmount Decimal
  oddTaken    Decimal?
  status      PickResultStatus @default(PENDING)
  profitLoss  Decimal?
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  pick        Pick             @relation(fields: [pickId], references: [id])
  createdAt   DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime         @updatedAt @db.Timestamptz(6)

  @@index([userId])
}
